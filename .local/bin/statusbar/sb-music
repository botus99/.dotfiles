#!/bin/sh

TERMINAL="/usr/local/bin/st"
META='{{ trunc(artist,17) }} - {{ trunc(title,17) }}'

# ensure daemon is running
pidof -x sb-playerctlup >/dev/null 2>&1 || sb-playerctlup >/dev/null 2>&1 &

case $(playerctl status 2>/dev/null) in
  Playing) ICON="  " ;;
  Paused)  ICON="  " ;;
  *) exit 0 ;;
esac

META_OUTPUT=$(playerctl metadata --format "$META" 2>/dev/null)
echo "$ICON$META_OUTPUT"

case $BLOCK_BUTTON in
  1) setsid -f "$HOME/.config/rofi/music.sh" >/dev/null 2>&1 ; kill -RTMIN+11 "$(pidof "${STATUSBAR:-dwmblocks}")" ;;
  2) playerctl play-pause >/dev/null 2>&1 ; kill -RTMIN+11 "$(pidof "${STATUSBAR:-dwmblocks}")" ;;
  3) setsid -f "$TERMINAL" -e ncmpcpp >/dev/null 2>&1 ; kill -RTMIN+11 "$(pidof "${STATUSBAR:-dwmblocks}")" ;;
  4) wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ;;
  5) wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
esac
